# RaiseKit — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Server
PORT=3000
NODE_ENV=development

# Session
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# Supabase
# Find these in your Supabase project → Settings → API
# Use the "service_role" secret key (not the anon/public key) for server-side access.
# Keep this key private — it bypasses Row Level Security.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
